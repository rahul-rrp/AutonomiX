// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  googleId  String?  @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents       AgentConfig[]
  integrations UserIntegration[]

  @@map("users")
}

model AgentConfig {
  id            String     @id @default(uuid())
  name          String
  tools         String[]
  role          String
  memoryEnabled Boolean
  run           AgentRun[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User?      @relation(fields: [userId], references: [id])
  userId        String?

  @@map("agent_config")
}

model AgentRun {
  id        String   @id @default(uuid())
  agentId   String
  task      String
  response  String
  createdAt DateTime @default(now())

  agent AgentConfig @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_run")
}

model UserIntegration {
  id       String @id @default(uuid())
  userId   String
  provider String
  // "google_calendar" | "gmail" | "slack" | "notion" | "news_api" | "weather" | "custom"

  authType String
  // "oauth" | "apikey"

  // ── OAuth fields ──────────────────────────────────────
  refreshToken String?
  accessToken  String?
  expiresAt    DateTime?
  scope        String?

  // ── API Key fields ────────────────────────────────────
  apiKey  String?
  apiUrl  String? // for custom APIs only
  apiName String? // display name for custom APIs

  // ── Metadata ──────────────────────────────────────────
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ─────────────────────────────────────────
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_integrations")
}
